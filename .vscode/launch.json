{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run my-axum",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "build",
                    "--bin",
                    "my-axum"
                ],
                "filter": {
                    "name": "my-axum",
                    "kind": "bin"
                }
            },
            "args": []
        },
        {
            "name": "Run worker",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "build",
                    "--bin",
                    "worker"
                ],
                "filter": {
                    "name": "worker",
                    "kind": "bin"
                }
            },
            "args": []
        }
    ],
    "compounds": [
        {
            "name": "Run axum + worker",
            "configurations": [
                "Run my-axum",
                "Run worker"
            ],
            "stopAll": true
        }
    ]
}
